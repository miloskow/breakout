import pygame
pygame.init()
HEIGHT, WIDTH = 600, 600

screen = pygame.display.set_mode((WIDTH, HEIGHT))
pygame.display.set_caption("Breakout")

from level import Level

game = Level()

while True:

    Level.clock.tick(60)

    for event in pygame.event.get():
        if event.type == pygame.QUIT:
            pygame.quit()
            exit()

    if game.run:

        game.handle_input()
        game.update_ball()
        game.check_brick_collision()
        game.draw(screen)
        game.update()

    else:
        game.game_over(screen)

    if game.try_again:
        game = Level()


pygame.quit()